# Solana RPC endpoint (default: https://api.mainnet-beta.solana.com)
# Tip: Use My Menu > RPC Settings in the CLI to set this interactively
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Path to your Solana keypair JSON file (optional — auto-detected if omitted)
# SOLANA_KEYPAIR_PATH=./keypair.json
